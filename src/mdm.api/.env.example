# MDM Server Configuration
# Copy this file to .env and fill in the values

# Server
LISTEN_ADDR=:8080

# PostgreSQL
DATABASE_URL=postgres://mdm:mdm@localhost:5432/mdm?sslmode=disable

# JWT (use a strong random string, at least 32 characters)
JWT_SECRET=change-me-in-production

# MicroMDM
MICROMDM_URL=https://mdm.example.com
MICROMDM_API_KEY=your-api-key-here

# Apple VPP (optional)
VPP_TOKEN_PATH=

# Webhook
WEBHOOK_PATH=/webhook

# SocketIO webhook relay server (connects as client to receive MDM events)
WEBSOCKET_URL=https://websocket.example.com

# CORS (comma-separated origins, used in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Apple Business Manager API (for DEP auto-assignment) ===
# Get these from Apple Business Manager → Preferences → API → your API account.
# The PEM is the EC P-256 private key you uploaded the public half of.
# Leave DEP_AUTO_ASSIGN=false until you've placed template files in DEP_TEMPLATE_DIR.
ABM_KEY_PATH=/path/to/abm-private-key.pem
ABM_CLIENT_ID=BUSINESSAPI.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ABM_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ABM_TEAM_ID=    # optional, defaults to ABM_CLIENT_ID (Apple's sample uses same value)
# ABM_SCOPE=business.api    # default

# === DEP auto-assignment scheduler ===
# Template files: $DEP_TEMPLATE_DIR/{mac,ipad,iphone,appletv}.json
# Each template is a full DEP profile body (same shape as
# `mdmctl apply dep-profiles -f` consumes). Leave the "devices" field empty —
# the scheduler fills it in per device.
DEP_TEMPLATE_DIR=./dep-profiles
DEP_POLL_INTERVAL=5m
DEP_AUTO_ASSIGN=false   # master switch — set to true to enable the scheduler
